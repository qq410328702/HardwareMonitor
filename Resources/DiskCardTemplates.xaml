<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:conv="clr-namespace:HardwareMonitor.Converters">
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>
    <conv:TempToColorConverter x:Key="TempColor"/>
    <conv:FloatFormatConverter x:Key="FloatFmt"/>
    <conv:RatioToWidthConverter x:Key="RatioToWidth"/>
    <conv:DiskHealthStatusToBrushConverter x:Key="DiskHealthBrush"/>

    <DataTemplate x:Key="DiskCardContentTemplate">
        <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                Padding="12" MinWidth="320" MinHeight="100">
            <StackPanel>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0"
                             Fill="{Binding Health, Converter={StaticResource DiskHealthBrush}}"
                             VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                </Grid>
                <TextBlock Text="{Binding DiskMetaText}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis" Margin="14,0,0,7"/>

                <UniformGrid Columns="4" Margin="0,0,0,6">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="状态" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LifetimeStatusText}" FontSize="13"
                                   Foreground="{Binding Health, Converter={StaticResource DiskHealthBrush}}"
                                   HorizontalAlignment="Center"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="剩余寿命" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LifeRemainingDisplay}" FontSize="13"
                                   Foreground="{Binding Health, Converter={StaticResource DiskHealthBrush}}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="已用寿命" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding LifeUsedDisplay}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="温度" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{Binding Temperature, Converter={StaticResource TempColor}}">
                            <Run Text="{Binding Temperature, Converter={StaticResource FloatFmt}, ConverterParameter=F1, Mode=OneWay}"/>
                            <Run Text="°C"/>
                        </TextBlock>
                    </StackPanel>
                </UniformGrid>

                <Grid Height="6" Margin="0,0,0,8"
                      Visibility="{Binding HasLifePercent, Converter={StaticResource BoolToVis}}">
                    <Border Background="#20888888" CornerRadius="3"/>
                    <Border HorizontalAlignment="Left" CornerRadius="3"
                            Background="{Binding Health, Converter={StaticResource DiskHealthBrush}}">
                        <Border.Width>
                            <MultiBinding Converter="{StaticResource RatioToWidth}">
                                <Binding Path="LifeRemainingBarPercent"/>
                                <Binding RelativeSource="{RelativeSource AncestorType=Grid}" Path="ActualWidth"/>
                            </MultiBinding>
                        </Border.Width>
                    </Border>
                </Grid>

                <UniformGrid Columns="3" Margin="0,0,0,8">
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="读取" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="{Binding ReadSpeed, Converter={StaticResource FloatFmt}, ConverterParameter=F1, Mode=OneWay}"/>
                            <Run Text="MB/s"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="写入" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock FontSize="13" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource TextPrimaryBrush}">
                            <Run Text="{Binding WriteSpeed, Converter={StaticResource FloatFmt}, ConverterParameter=F1, Mode=OneWay}"/>
                            <Run Text="MB/s"/>
                        </TextBlock>
                    </StackPanel>
                    <StackPanel HorizontalAlignment="Center">
                        <TextBlock Text="备用空间" FontSize="12"
                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                        <TextBlock Text="{Binding AvailableSpareDisplay}" FontSize="13"
                                   Foreground="{DynamicResource TextPrimaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </UniformGrid>

                <TextBlock Text="{Binding LifetimeUnavailableReason}" FontSize="11"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           TextWrapping="Wrap" Margin="0,0,0,6"
                           Visibility="{Binding HasLifetimeUnavailableReason, Converter={StaticResource BoolToVis}}"/>

                <Grid Margin="0,2,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="累计读取" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasTotalIo, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding TotalReadDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,14,1"
                               Visibility="{Binding HasTotalIo, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="累计写入" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasTotalIo, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding TotalWrittenDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,1"
                               Visibility="{Binding HasTotalIo, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="通电时间" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasPowerCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding PowerOnDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,14,1"
                               Visibility="{Binding HasPowerCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="通电次数" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasPowerCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding PowerCycleDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,1"
                               Visibility="{Binding HasPowerCounters, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="不安全关机" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasShutdownOrCriticalWarning, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UnsafeShutdownDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,14,1"
                               Visibility="{Binding HasShutdownOrCriticalWarning, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="严重警告" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasShutdownOrCriticalWarning, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding CriticalWarningDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,1"
                               Visibility="{Binding HasShutdownOrCriticalWarning, Converter={StaticResource BoolToVis}}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="介质错误" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasErrorCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding MediaErrorDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,14,1"
                               Visibility="{Binding HasErrorCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="错误日志" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,1,8,1"
                               Visibility="{Binding HasErrorCounters, Converter={StaticResource BoolToVis}}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding ErrorLogEntryDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,1,0,1"
                               Visibility="{Binding HasErrorCounters, Converter={StaticResource BoolToVis}}"/>
                </Grid>
            </StackPanel>
        </Border>
    </DataTemplate>
</ResourceDictionary>
