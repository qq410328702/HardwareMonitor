<Window x:Class="HardwareMonitor.DiskBadSectorDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:HardwareMonitor.Converters"
        xmlns:piw="clr-namespace:PhosphorIconsWpf.Markup;assembly=PhosphorIconsWpf"
        Title="坏道检测" Icon="Resources/AppIcon.ico"
        Width="620" SizeToContent="Height"
        MinWidth="560" MaxWidth="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <conv:DiskBadSectorRiskToBrushConverter x:Key="BadSectorRiskBrush"/>

        <Style x:Key="DialogIconPathStyle" TargetType="{x:Type Path}">
            <Setter Property="Width" Value="16"/>
            <Setter Property="Height" Value="16"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="DialogButtonIconPathStyle" TargetType="{x:Type Path}" BasedOn="{StaticResource DialogIconPathStyle}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
        </Style>

        <Style x:Key="DialogButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource MiniCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>

        <Style x:Key="CounterLabelStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,8,2"/>
        </Style>

        <Style x:Key="CounterValueStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="Margin" Value="0,2,14,2"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Padding="18">
        <StackPanel>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Path Data="{piw:IconGeometry Icon=magnifying_glass, IconType=regular}"
                      Width="38" Height="38" Stretch="Uniform"
                      Fill="{Binding BadSectorRisk, Converter={StaticResource BadSectorRiskBrush}}"
                      Margin="0,0,14,0"/>

                <StackPanel Grid.Column="1">
                    <TextBlock Text="SMART 坏道风险检测"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock Text="{Binding Name}" FontSize="12"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding DiskMetaText}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis" Margin="0,2,0,0"/>
                </StackPanel>

                <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding BadSectorStatusText}" FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="{Binding BadSectorRisk, Converter={StaticResource BadSectorRiskBrush}}"
                               TextAlignment="Right"/>
                    <TextBlock Text="{Binding BadSectorLastCheckedDisplay}" FontSize="11"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               TextAlignment="Right" Margin="0,3,0,0"/>
                </StackPanel>
            </Grid>

            <TextBlock Text="{Binding BadSectorRiskReason}" FontSize="12"
                       Foreground="{DynamicResource TextPrimaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,8"
                       Visibility="{Binding HasBadSectorRiskReason, Converter={StaticResource BoolToVis}}"/>

            <TextBlock Text="{Binding BadSectorUnavailableReason}" FontSize="12"
                       Foreground="{DynamicResource TextSecondaryBrush}"
                       TextWrapping="Wrap" Margin="0,0,0,8"
                       Visibility="{Binding HasBadSectorUnavailableReason, Converter={StaticResource BoolToVis}}"/>

            <Border Background="{DynamicResource MiniCardBrush}" CornerRadius="8"
                    Padding="10" Margin="0,0,0,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="重映射扇区" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding ReallocatedSectorDisplay}" Style="{StaticResource CounterValueStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="2" Text="待映射扇区" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="0" Grid.Column="3" Text="{Binding CurrentPendingSectorDisplay}" Style="{StaticResource CounterValueStyle}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="离线不可纠正" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding OfflineUncorrectableSectorDisplay}" Style="{StaticResource CounterValueStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="2" Text="介质错误" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="1" Grid.Column="3" Text="{Binding MediaErrorDisplay}" Style="{StaticResource CounterValueStyle}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="不可纠正读取" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding UncorrectableReadErrorDisplay}" Style="{StaticResource CounterValueStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="2" Text="不可纠正写入" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="2" Grid.Column="3" Text="{Binding UncorrectableWriteErrorDisplay}" Style="{StaticResource CounterValueStyle}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="不可纠正错误" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding UncorrectableErrorDisplay}" Style="{StaticResource CounterValueStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="2" Text="错误日志" Style="{StaticResource CounterLabelStyle}"/>
                    <TextBlock Grid.Row="3" Grid.Column="3" Text="{Binding ErrorLogEntryDisplay}" Style="{StaticResource CounterValueStyle}"/>
                </Grid>
            </Border>

            <Grid Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="120"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="只读扫描盘符" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox x:Name="DriveLetterCombo" Grid.Column="1"
                          Height="28" FontSize="12"
                          VerticalContentAlignment="Center"/>
                <TextBlock x:Name="ScanHintText" Grid.Column="2"
                           Text="只读检测，不执行修复；完整扫描可能较慢。"
                           FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                           VerticalAlignment="Center" Margin="10,0,10,0"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal">
                    <Button x:Name="QuickScanButton" Click="QuickScan_Click"
                            Style="{StaticResource DialogButtonStyle}" Margin="0,0,6,0">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{piw:IconGeometry Icon=magnifying_glass, IconType=bold}"
                                  Style="{StaticResource DialogButtonIconPathStyle}" Margin="0,0,5,0"/>
                            <TextBlock Text="快速扫描" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button x:Name="FullScanButton" Click="FullScan_Click"
                            Style="{StaticResource DialogButtonStyle}">
                        <StackPanel Orientation="Horizontal">
                            <Path Data="{piw:IconGeometry Icon=hard_drive, IconType=bold}"
                                  Style="{StaticResource DialogButtonIconPathStyle}" Margin="0,0,5,0"/>
                            <TextBlock Text="完整扫描" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <ProgressBar x:Name="ScanProgressBar" Height="5" Minimum="0" Maximum="100"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         Background="{DynamicResource MiniBarBgBrush}"
                         BorderThickness="0" Margin="0,0,0,8"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock x:Name="ScanStatusText" Text="请选择盘符后开始扫描"
                               FontSize="12" Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="ScanProgressText" Text="--"
                               FontSize="11" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,3,0,0"/>
                </StackPanel>
                <Button x:Name="CancelScanButton" Grid.Column="1" Click="CancelScan_Click"
                        Style="{StaticResource DialogButtonStyle}" IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{piw:IconGeometry Icon=x, IconType=bold}"
                              Style="{StaticResource DialogButtonIconPathStyle}" Margin="0,0,5,0"/>
                        <TextBlock Text="取消" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <Border Background="{DynamicResource MiniCardBrush}" CornerRadius="8"
                    Padding="10" Margin="0,0,0,14">
                <StackPanel>
                    <Grid Margin="0,0,0,6">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="读取错误块" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="FailureCountText" Grid.Column="1" Text="0"
                                   FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource AccentRedBrush}"/>
                    </Grid>

                    <ScrollViewer MaxHeight="140" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled">
                        <ItemsControl x:Name="FailuresList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Margin="0,3,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="96"/>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="88"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding OffsetDisplay}" FontSize="11"
                                                   Foreground="{DynamicResource TextPrimaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding LengthDisplay}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding ErrorCode}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="3" Text="{Binding Message}" FontSize="11"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Click="Close_Click" Style="{StaticResource DialogButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{piw:IconGeometry Icon=check_circle, IconType=bold}"
                              Style="{StaticResource DialogButtonIconPathStyle}" Margin="0,0,5,0"/>
                        <TextBlock Text="关闭" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
