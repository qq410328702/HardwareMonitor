<Window x:Class="HardwareMonitor.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ctrl="clr-namespace:HardwareMonitor.Controls"
        xmlns:conv="clr-namespace:HardwareMonitor.Converters"
        xmlns:piw="clr-namespace:PhosphorIconsWpf.Markup;assembly=PhosphorIconsWpf"
        Title="Hardware Monitor" Icon="Resources/AppIcon.ico" Width="980" Height="720"
        MinWidth="800" MinHeight="600"
        Background="{DynamicResource BgDarkBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Resources/DiskCardTemplates.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <BooleanToVisibilityConverter x:Key="BoolToVis"/>
            <conv:TempToWpfColorConverter x:Key="TempWpfColor"/>
            <conv:FloatFormatConverter x:Key="FloatFmt"/>
            <conv:RatioToWidthConverter x:Key="RatioToWidth"/>

            <Style x:Key="IconPathStyle" TargetType="{x:Type Path}">
                <Setter Property="Width" Value="16"/>
                <Setter Property="Height" Value="16"/>
                <Setter Property="Stretch" Value="Uniform"/>
                <Setter Property="Fill" Value="{DynamicResource TextSecondaryBrush}"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
            </Style>

            <Style x:Key="CardIconPathStyle" TargetType="{x:Type Path}" BasedOn="{StaticResource IconPathStyle}">
                <Setter Property="Width" Value="18"/>
                <Setter Property="Height" Value="18"/>
            </Style>

            <Style x:Key="ButtonIconPathStyle" TargetType="{x:Type Path}" BasedOn="{StaticResource IconPathStyle}">
                <Setter Property="Width" Value="13"/>
                <Setter Property="Height" Value="13"/>
            </Style>

            <Style x:Key="ElectricityTextBoxStyle" TargetType="{x:Type TextBox}">
                <Setter Property="Background" Value="{DynamicResource MiniCardBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="5,3"/>
                <Setter Property="MinHeight" Value="24"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="VerticalContentAlignment" Value="Center"/>
            </Style>

            <Style x:Key="ElectricityButtonStyle" TargetType="{x:Type Button}">
                <Setter Property="Background" Value="{DynamicResource MiniCardBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
                <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="Padding" Value="8,4"/>
                <Setter Property="MinHeight" Value="26"/>
                <Setter Property="FontSize" Value="11"/>
                <Setter Property="Cursor" Value="Hand"/>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Border CornerRadius="12" Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="Transparent" MouseLeftButtonDown="TitleBar_MouseDown">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" Margin="16,0,0,0" VerticalAlignment="Center">
                    <Path Data="{piw:IconGeometry Icon=gauge, IconType=regular}"
                          Style="{StaticResource IconPathStyle}"
                          Fill="{DynamicResource AccentGreenBrush}" Margin="0,0,7,0"/>
                    <TextBlock Text="Hardware Monitor" Foreground="{DynamicResource TextPrimaryBrush}"
                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,8,0">
                    <ComboBox x:Name="ThemeCombo"
                              ItemsSource="{Binding ThemeNames}"
                              SelectedIndex="{Binding ThemeIndex}"
                              Width="80" Height="24" FontSize="11" VerticalAlignment="Center"
                              Margin="0,0,4,0" ToolTip="切换主题"/>
                    <Button Click="MiniMode_Click" Style="{x:Null}"
                            Width="36" Height="28" ToolTip="切换悬浮窗"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="{piw:IconGeometry Icon=arrows_in, IconType=bold}"
                              Style="{StaticResource ButtonIconPathStyle}"/>
                    </Button>
                    <Button Click="Minimize_Click" Style="{x:Null}"
                            Width="36" Height="28" ToolTip="最小化"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="{piw:IconGeometry Icon=minus, IconType=bold}"
                              Style="{StaticResource ButtonIconPathStyle}"/>
                    </Button>
                    <Button Click="Close_Click" Style="{x:Null}"
                            Width="36" Height="28" ToolTip="关闭"
                            Background="Transparent" BorderThickness="0" Cursor="Hand">
                        <Path Data="{piw:IconGeometry Icon=x, IconType=bold}"
                              Style="{StaticResource ButtonIconPathStyle}"/>
                    </Button>
                </StackPanel>
            </Grid>

            <Border Grid.Row="1" x:Name="ErrorPanel"
                    Visibility="{Binding IsError, Converter={StaticResource BoolToVis}}"
                    Background="{DynamicResource BgDarkBrush}" Panel.ZIndex="2">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Margin="40">
                    <Path Data="{piw:IconGeometry Icon=warning_circle, IconType=regular}"
                          Width="48" Height="48" Stretch="Uniform"
                          Fill="{DynamicResource AccentRedBrush}" Margin="0,0,0,16"/>
                    <TextBlock Text="硬件监控初始化失败" FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"
                               HorizontalAlignment="Center" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding ErrorMessage}" FontSize="13"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center" TextWrapping="Wrap"
                               MaxWidth="500" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <Border Grid.Row="1" x:Name="LoadingPanel"
                    Background="{DynamicResource BgDarkBrush}" Panel.ZIndex="1">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}" Value="True"/>
                                    <Condition Binding="{Binding IsError}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                                 Foreground="{DynamicResource AccentGreenBrush}"
                                 Background="#20888888" BorderThickness="0" Margin="0,0,0,16"/>
                    <TextBlock Text="正在初始化硬件监控..." FontSize="14"
                               Foreground="{DynamicResource TextSecondaryBrush}"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="20,8,20,20">
                <ScrollViewer.Style>
                    <Style TargetType="ScrollViewer">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <MultiDataTrigger>
                                <MultiDataTrigger.Conditions>
                                    <Condition Binding="{Binding IsLoading}" Value="False"/>
                                    <Condition Binding="{Binding IsError}" Value="False"/>
                                </MultiDataTrigger.Conditions>
                                <Setter Property="Visibility" Value="Visible"/>
                            </MultiDataTrigger>
                        </Style.Triggers>
                    </Style>
                </ScrollViewer.Style>

                <StackPanel x:Name="DashboardGroups">
                    <StackPanel x:Name="HardwareGroup" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
                            <Path Data="{piw:IconGeometry Icon=cpu, IconType=regular}"
                                  Style="{StaticResource IconPathStyle}"
                                  Fill="{DynamicResource AccentBlueBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="硬件概览" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel x:Name="HardwareCardPanel" Orientation="Horizontal">
                            <Border x:Name="Card_cpu" Tag="cpu" Background="Transparent" Margin="4">
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                                        Padding="12" MinWidth="170">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <Path Data="{piw:IconGeometry Icon=cpu, IconType=regular}"
                                                  Style="{StaticResource IconPathStyle}"
                                                  Fill="{DynamicResource AccentBlueBrush}" Margin="0,0,5,0"/>
                                            <TextBlock Text="CPU 温度" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ctrl:ArcGauge Width="130" Height="130"
                                                       Value="{Binding CpuTemp}" MaxValue="100" Unit="°C" Label="TEMP"
                                                       AccentColor="{Binding CpuTemp, Converter={StaticResource TempWpfColor}}"/>
                                        <TextBlock Text="{Binding CpuName}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <Border x:Name="Card_gpu" Tag="gpu" Background="Transparent" Margin="4">
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                                        Padding="12" MinWidth="170">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <Path Data="{piw:IconGeometry Icon=graphics_card, IconType=regular}"
                                                  Style="{StaticResource IconPathStyle}"
                                                  Fill="{DynamicResource AccentGreenBrush}" Margin="0,0,5,0"/>
                                            <TextBlock Text="GPU 温度" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ctrl:ArcGauge Width="130" Height="130"
                                                       Value="{Binding GpuTemp}" MaxValue="100" Unit="°C" Label="TEMP"
                                                       AccentColor="{Binding GpuTemp, Converter={StaticResource TempWpfColor}}"/>
                                        <TextBlock Text="{Binding GpuName}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="160"/>
                                    </StackPanel>
                                </Border>
                            </Border>

                            <Border x:Name="Card_memory" Tag="memory" Background="Transparent" Margin="4">
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                                        Padding="12" MinWidth="170">
                                    <StackPanel HorizontalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,0,0,4">
                                            <Path Data="{piw:IconGeometry Icon=memory, IconType=regular}"
                                                  Style="{StaticResource IconPathStyle}"
                                                  Fill="{DynamicResource AccentPurpleBrush}" Margin="0,0,5,0"/>
                                            <TextBlock Text="内存使用率" Foreground="{DynamicResource TextSecondaryBrush}"
                                                       FontSize="14" VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <ctrl:ArcGauge Width="130" Height="130"
                                                       Value="{Binding MemUsage}" MaxValue="100" Unit="%" Label="RAM"
                                                       AccentColor="{DynamicResource AccentPurple}"/>
                                        <TextBlock Foreground="{DynamicResource TextSecondaryBrush}"
                                                   FontSize="12" HorizontalAlignment="Center" Margin="0,2,0,0">
                                            <Run Text="{Binding MemUsed, Converter={StaticResource FloatFmt}, ConverterParameter=F1, Mode=OneWay}"/>
                                            <Run Text="/"/>
                                            <Run Text="{Binding MemTotal, Converter={StaticResource FloatFmt}, ConverterParameter=F1, Mode=OneWay}"/>
                                            <Run Text="GB"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel x:Name="PowerGroup" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
                            <Path Data="{piw:IconGeometry Icon=lightning, IconType=regular}"
                                  Style="{StaticResource IconPathStyle}"
                                  Fill="{DynamicResource AccentOrangeBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="功耗统计" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel x:Name="PowerCardPanel" Orientation="Horizontal">
                            <Border x:Name="Card_power" Tag="power" Background="Transparent" Margin="4">
                                <Border Background="{DynamicResource BgCardBrush}" CornerRadius="12"
                                        Padding="14" MinWidth="430" MaxWidth="540">
                                    <StackPanel>
                                        <Grid Margin="0,0,0,10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{piw:IconGeometry Icon=plug_charging, IconType=regular}"
                                                          Style="{StaticResource IconPathStyle}"
                                                          Fill="{DynamicResource AccentOrangeBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="总功耗" Foreground="{DynamicResource TextSecondaryBrush}"
                                                               FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding PowerSourceText}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Top">
                                                <TextBlock Text="{Binding TotalPower, Converter={StaticResource FloatFmt}, ConverterParameter=F0}"
                                                           Foreground="{DynamicResource AccentOrangeBrush}"
                                                           FontSize="28" FontWeight="Bold"/>
                                                <TextBlock Text="W" Foreground="{DynamicResource AccentOrangeBrush}"
                                                           FontSize="14" FontWeight="SemiBold"
                                                           VerticalAlignment="Bottom" Margin="3,0,0,5"/>
                                            </StackPanel>
                                        </Grid>

                                        <StackPanel>
                                            <StackPanel.Style>
                                                <Style TargetType="StackPanel">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPowerReadings}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </StackPanel.Style>

                                            <Grid Margin="0,0,0,4">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="52"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="68"/>
                                                    <ColumnDefinition Width="40"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0" Text="类型" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="1" Text="传感器" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Grid.Column="2" Text="瓦数" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                                <TextBlock Grid.Column="3" Text="口径" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}" TextAlignment="Right"/>
                                            </Grid>

                                            <ScrollViewer MaxHeight="190" VerticalScrollBarVisibility="Auto"
                                                          HorizontalScrollBarVisibility="Disabled">
                                                <ItemsControl ItemsSource="{Binding PowerReadings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Grid Margin="0,5,0,0">
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto"/>
                                                                    <RowDefinition Height="5"/>
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="52"/>
                                                                    <ColumnDefinition Width="*"/>
                                                                    <ColumnDefinition Width="68"/>
                                                                    <ColumnDefinition Width="40"/>
                                                                </Grid.ColumnDefinitions>
                                                                <TextBlock Grid.Column="0" Text="{Binding Category}" FontSize="12"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"/>
                                                                <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12"
                                                                           Foreground="{DynamicResource TextPrimaryBrush}"
                                                                           TextTrimming="CharacterEllipsis"/>
                                                                <TextBlock Grid.Column="2" Text="{Binding WattsDisplay}" FontSize="12"
                                                                           Foreground="{DynamicResource AccentOrangeBrush}"
                                                                           TextAlignment="Right" FontWeight="SemiBold"/>
                                                                <TextBlock Grid.Column="3" Text="{Binding InclusionText}" FontSize="11"
                                                                           Foreground="{DynamicResource TextSecondaryBrush}"
                                                                           TextAlignment="Right"/>

                                                                <Grid x:Name="PowerShareBar" Grid.Row="1" Grid.Column="1"
                                                                      Grid.ColumnSpan="3" Height="3" Margin="0,2,0,0">
                                                                    <Border Background="{DynamicResource MiniBarBgBrush}" CornerRadius="2"/>
                                                                    <Border Background="{DynamicResource AccentOrangeBrush}" CornerRadius="2"
                                                                            HorizontalAlignment="Left">
                                                                        <Border.Width>
                                                                            <MultiBinding Converter="{StaticResource RatioToWidth}">
                                                                                <Binding Path="SharePercent"/>
                                                                                <Binding Path="ActualWidth" ElementName="PowerShareBar"/>
                                                                            </MultiBinding>
                                                                        </Border.Width>
                                                                    </Border>
                                                                </Grid>
                                                            </Grid>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </ScrollViewer>
                                        </StackPanel>

                                        <TextBlock Text="{Binding PowerUnavailableReason}" FontSize="12"
                                                   Foreground="{DynamicResource TextSecondaryBrush}"
                                                   TextWrapping="Wrap" Margin="0,4,0,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasPowerReadings}" Value="False">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <Border Height="1" Background="{DynamicResource BorderBrush}"
                                                Opacity="0.6" Margin="0,12,0,10"/>

                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal">
                                                    <Path Data="{piw:IconGeometry Icon=currency_cny, IconType=regular}"
                                                          Style="{StaticResource IconPathStyle}"
                                                          Fill="{DynamicResource AccentGreenBrush}" Margin="0,0,6,0"/>
                                                    <TextBlock Text="电费统计" Foreground="{DynamicResource TextPrimaryBrush}"
                                                               FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding ElectricityStatus}" Foreground="{DynamicResource TextSecondaryBrush}"
                                                           FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding CurrentElectricityRateDisplay}"
                                                       Foreground="{DynamicResource AccentGreenBrush}"
                                                       FontSize="12" FontWeight="SemiBold" VerticalAlignment="Top"/>
                                        </Grid>

                                        <UniformGrid Columns="3" Margin="0,0,0,10">
                                            <StackPanel Margin="0,0,8,0">
                                                <TextBlock Text="今日" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding TodayElectricityKwhDisplay}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TodayElectricityCostDisplay}" FontSize="12"
                                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                                            </StackPanel>
                                            <StackPanel Margin="4,0,4,0">
                                                <TextBlock Text="本月" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding MonthElectricityKwhDisplay}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding MonthElectricityCostDisplay}" FontSize="12"
                                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                                            </StackPanel>
                                            <StackPanel Margin="8,0,0,0">
                                                <TextBlock Text="总计" FontSize="11"
                                                           Foreground="{DynamicResource TextSecondaryBrush}"/>
                                                <TextBlock Text="{Binding TotalElectricityKwhDisplay}" FontSize="13"
                                                           Foreground="{DynamicResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                                <TextBlock Text="{Binding TotalElectricityCostDisplay}" FontSize="12"
                                                           Foreground="{DynamicResource AccentGreenBrush}"/>
                                            </StackPanel>
                                        </UniformGrid>

                                        <Grid Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="62"/>
                                                <ColumnDefinition Width="62"/>
                                                <ColumnDefinition Width="78"/>
                                                <ColumnDefinition Width="34"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0" Text="名称" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="1" Text="开始" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="结束" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                            <TextBlock Grid.Column="3" Text="元/kWh" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"/>
                                        </Grid>

                                        <ItemsControl ItemsSource="{Binding ElectricityTariffPeriods}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Grid Margin="0,3,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="62"/>
                                                            <ColumnDefinition Width="62"/>
                                                            <ColumnDefinition Width="78"/>
                                                            <ColumnDefinition Width="34"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Grid.Column="0" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ElectricityTextBoxStyle}" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Column="1" Text="{Binding StartTime, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ElectricityTextBoxStyle}" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Column="2" Text="{Binding EndTime, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ElectricityTextBoxStyle}" Margin="0,0,5,0"/>
                                                        <TextBox Grid.Column="3" Text="{Binding RateYuanPerKwh, UpdateSourceTrigger=PropertyChanged}"
                                                                 Style="{StaticResource ElectricityTextBoxStyle}" Margin="0,0,5,0"/>
                                                        <Button Grid.Column="4" Click="RemoveElectricityTariff_Click"
                                                                Style="{StaticResource ElectricityButtonStyle}" Padding="0"
                                                                ToolTip="删除时段">
                                                            <Path Data="{piw:IconGeometry Icon=trash, IconType=bold}"
                                                                  Style="{StaticResource ButtonIconPathStyle}"
                                                                  Fill="{DynamicResource AccentRedBrush}"/>
                                                        </Button>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>

                                        <Grid Margin="0,8,0,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding ElectricityConfigMessage}" FontSize="11"
                                                       Foreground="{DynamicResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <Button Click="AddElectricityTariff_Click"
                                                        Style="{StaticResource ElectricityButtonStyle}" Margin="0,0,5,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{piw:IconGeometry Icon=plus, IconType=bold}"
                                                              Style="{StaticResource ButtonIconPathStyle}" Margin="0,0,4,0"/>
                                                        <TextBlock Text="新增时段" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="RestoreElectricityTariffs_Click"
                                                        Style="{StaticResource ElectricityButtonStyle}" Margin="0,0,5,0">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{piw:IconGeometry Icon=arrow_counter_clockwise, IconType=bold}"
                                                              Style="{StaticResource ButtonIconPathStyle}" Margin="0,0,4,0"/>
                                                        <TextBlock Text="恢复默认" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Click="SaveElectricityTariffs_Click"
                                                        Style="{StaticResource ElectricityButtonStyle}">
                                                    <StackPanel Orientation="Horizontal">
                                                        <Path Data="{piw:IconGeometry Icon=floppy_disk, IconType=bold}"
                                                              Style="{StaticResource ButtonIconPathStyle}" Margin="0,0,4,0"/>
                                                        <TextBlock Text="保存电价" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>
                            </Border>
                        </WrapPanel>
                    </StackPanel>

                    <StackPanel x:Name="StorageGroup" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal" Margin="4,0,0,6">
                            <Path Data="{piw:IconGeometry Icon=hard_drives, IconType=regular}"
                                  Style="{StaticResource IconPathStyle}"
                                  Fill="{DynamicResource AccentGreenBrush}" Margin="0,0,6,0"/>
                            <TextBlock Text="存储设备" Foreground="{DynamicResource TextSecondaryBrush}"
                                       FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center"/>
                        </StackPanel>
                        <WrapPanel x:Name="StorageCardPanel" Orientation="Horizontal"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
