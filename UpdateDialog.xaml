<Window x:Class="HardwareMonitor.UpdateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:piw="clr-namespace:PhosphorIconsWpf.Markup;assembly=PhosphorIconsWpf"
        Title="版本更新" Icon="Resources/AppIcon.ico"
        Width="520" SizeToContent="Height"
        MinWidth="480" MaxWidth="620"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource BgDarkBrush}">

    <Window.Resources>
        <Style x:Key="UpdateIconPathStyle" TargetType="{x:Type Path}">
            <Setter Property="Width" Value="36"/>
            <Setter Property="Height" Value="36"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="{DynamicResource AccentBlueBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="UpdateButtonIconPathStyle" TargetType="{x:Type Path}">
            <Setter Property="Width" Value="14"/>
            <Setter Property="Height" Value="14"/>
            <Setter Property="Stretch" Value="Uniform"/>
            <Setter Property="Fill" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
        </Style>

        <Style x:Key="UpdateButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="{DynamicResource MiniCardBrush}"/>
            <Setter Property="Foreground" Value="{DynamicResource TextPrimaryBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="MinHeight" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Border Background="{DynamicResource BgDarkBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
            Padding="18">
        <StackPanel>
            <Grid Margin="0,0,0,14">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Grid Width="44" Height="44" Margin="0,0,14,0">
                    <Path x:Name="CheckingIcon" Data="{piw:IconGeometry Icon=arrows_clockwise, IconType=regular}"
                          Style="{StaticResource UpdateIconPathStyle}"
                          Fill="{DynamicResource AccentBlueBrush}"/>
                    <Path x:Name="UpdateAvailableIcon" Data="{piw:IconGeometry Icon=download_simple, IconType=regular}"
                          Style="{StaticResource UpdateIconPathStyle}"
                          Fill="{DynamicResource AccentGreenBrush}" Visibility="Collapsed"/>
                    <Path x:Name="LatestIcon" Data="{piw:IconGeometry Icon=check_circle, IconType=regular}"
                          Style="{StaticResource UpdateIconPathStyle}"
                          Fill="{DynamicResource AccentGreenBrush}" Visibility="Collapsed"/>
                    <Path x:Name="ErrorIcon" Data="{piw:IconGeometry Icon=warning_circle, IconType=regular}"
                          Style="{StaticResource UpdateIconPathStyle}"
                          Fill="{DynamicResource AccentRedBrush}" Visibility="Collapsed"/>
                </Grid>

                <StackPanel Grid.Column="1">
                    <TextBlock x:Name="TitleText" Text="正在检查更新"
                               FontSize="18" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimaryBrush}"/>
                    <TextBlock x:Name="StatusText" Text="正在连接 GitHub Releases..."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               Margin="0,4,0,0" TextWrapping="Wrap"/>
                </StackPanel>
            </Grid>

            <ProgressBar x:Name="ProgressBar" Height="4" IsIndeterminate="True"
                         Foreground="{DynamicResource AccentBlueBrush}"
                         Background="{DynamicResource MiniBarBgBrush}"
                         BorderThickness="0" Margin="0,0,0,14"/>

            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Text="当前版本" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,5"/>
                <TextBlock x:Name="CurrentVersionText" Grid.Row="0" Grid.Column="1" Text="--" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}" Margin="0,0,0,5"/>

                <TextBlock Grid.Row="1" Grid.Column="0" Text="最新版本" FontSize="12"
                           Foreground="{DynamicResource TextSecondaryBrush}" Margin="0,0,14,0"/>
                <TextBlock x:Name="LatestVersionText" Grid.Row="1" Grid.Column="1" Text="--" FontSize="12"
                           Foreground="{DynamicResource TextPrimaryBrush}"/>
            </Grid>

            <Border Background="{DynamicResource MiniCardBrush}" CornerRadius="8"
                    Padding="10" Margin="0,0,0,14">
                <ScrollViewer MaxHeight="160" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="ReleaseNotesText" Text="正在获取更新说明..."
                               FontSize="12" Foreground="{DynamicResource TextSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="InstallButton" Click="InstallButton_Click"
                        Style="{StaticResource UpdateButtonStyle}" Margin="0,0,8,0"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{piw:IconGeometry Icon=download_simple, IconType=bold}"
                              Style="{StaticResource UpdateButtonIconPathStyle}" Margin="0,0,5,0"/>
                        <TextBlock Text="立即更新" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="ReleaseButton" Click="ReleaseButton_Click"
                        Style="{StaticResource UpdateButtonStyle}" Margin="0,0,8,0"
                        IsEnabled="False">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{piw:IconGeometry Icon=arrow_square_out, IconType=bold}"
                              Style="{StaticResource UpdateButtonIconPathStyle}" Margin="0,0,5,0"/>
                        <TextBlock Text="打开发布页" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>

                <Button x:Name="CloseButton" Click="CloseButton_Click"
                        Style="{StaticResource UpdateButtonStyle}">
                    <StackPanel Orientation="Horizontal">
                        <Path Data="{piw:IconGeometry Icon=x, IconType=bold}"
                              Style="{StaticResource UpdateButtonIconPathStyle}" Margin="0,0,5,0"/>
                        <TextBlock Text="稍后" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
